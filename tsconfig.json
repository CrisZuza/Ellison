{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "Bundler", // <--- THIS IS THE KEY FIX
    "outDir": "./",
    "jsx": "react-jsx",
    "allowImportingTsExtensions": true, 
    "noEmit": true, // Vite handles the emitting, so tsc only checks types
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "strict": false,
    "skipLibCheck": true
  },
  "include": ["server.ts", "src/**/*"]
}
