{
  "compilerOptions": {
    "target": "ES2020",
    "module": "NodeNext", 
    "moduleResolution": "NodeNext", 
    "outDir": "./dist",
    "rootDir": "./",
    "jsx": "react-jsx",
    "allowImportingTsExtensions": true, 
    "noEmit": false, 
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "strict": false,
    "skipLibCheck": true
  },
  "include": ["server.ts", "src/**/*"],
  "exclude": ["node_modules", "dist"]
}
